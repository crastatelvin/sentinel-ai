# that does the log parsing, threat classification, and Gemini
# analysis). The React dashboard is a consumer of the API — valuable,
# but not the repo's core identity. Marking it vendored tells GitHub's
# Linguist to attribute the primary language to the backend.
frontend/** linguist-vendored
